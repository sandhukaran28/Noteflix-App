# --- AWS ---
AWS_REGION=us-east-1
# When running on EC2, attach an IAM role and you can leave the keys blank.
# For local dev, populate from `aws configure` or paste here:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- App ---
PORT=8080
NODE_ENV=production
DATA_ROOT=/data
API_BASE_PATH=/api/v1
WEB_ORIGIN=http://localhost:3000,https://your-frontend.vercel.app

# --- S3 (your bucket — must be globally unique) ---
S3_BUCKET=your-noteflix-bucket
S3_PREFIX=noteflix/outputs
ASSETS_PREFIX=noteflix/assets

# --- DynamoDB ---
DDB_TABLE=noteflix

# --- Cognito ---
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_ADMIN_GROUP=Admin

# --- Bedrock (script generation) ---
BEDROCK_ENABLED=true
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# --- Piper TTS (paths inside the container, set by the Dockerfile) ---
# PIPER_BIN=piper
# PIPER_VOICE_A=/app/models/en_US-amy-medium.onnx
# PIPER_VOICE_B=/app/models/en_US-ryan-high.onnx

# --- Optional: Wikipedia fallback for thin PDFs ---
WIKI_ENABLED=false
WIKI_LANG=en

# --- Optional: Redis cache (otherwise in-memory) ---
# REDIS_HOST=localhost
# REDIS_PORT=6379

# --- Local dev convenience (lets you skip auth) ---
# DEV_USER_ID=local-dev-user
